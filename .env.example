PORT=10000

# Seguridad del webhook de Evolution hacia este bridge
EVOLUTION_WEBHOOK_SECRET=pon_un_secreto_largo

# Evolution
EVOLUTION_BASE_URL=https://TU-EVOLUTION.onrender.com
EVOLUTION_API_KEY=TU_API_KEY_GLOBAL_O_INSTANCE
EVOLUTION_INSTANCE=mi-instancia-grupo

# Tu bot actual (el que ya genera PDF con Cloud API)
BOT_INTERNAL_URL=https://TU-BOT.onrender.com/internal/generate-pdf
BOT_INTERNAL_TOKEN=pon_otro_token_largo

# Si quieres mandar también por Cloud API directo al usuario
WHATSAPP_TOKEN=EAA...
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_GRAPH_VERSION=v23.0

# Comportamiento
GROUP_COMMAND=/csf
SEND_PDF_TO_GROUP=true
SEND_PDF_TO_REQUESTER=true
SEND_PRIVATE_VIA=cloud

# permitidos: cloud | evolution
# si pones cloud: el privado sale por tu bot/meta
# si pones evolution: el privado sale por el numero conectado a evolution

ALLOWED_GROUPS=
# si quieres restringir a grupos específicos, separa por comas:
# 1234567890-123456789@g.us,9876543210-111111111@g.us
